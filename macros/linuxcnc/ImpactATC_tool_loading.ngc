; -------------------------------------------------
; open_atc_loading.ngc
; Subroutine: Load tool into spindle - ImpactATC
; -------------------------------------------------

;o<open_atc_loading> sub

;(DEBUG, ATC: Starting tool LOAD sequence)


; ================================
; MACHINE-SPECIFIC CALIBRATION
; ================================
; Z reference position when spindle (without nut) just touches top of ATC module
#<z_reference_spindle_touch> = -62


; ================================
; DERIVED / POSITION PARAMETERS
; ================================
#<z_safe_machine>        = 0        ; Safe Z height in machine coordinates
#<z_engage_offset>       = 16       ; Offset above reference to begin engagement
#<z_engage_position>     = [#<z_reference_spindle_touch> + #<z_engage_offset>]

#<z_step_initial_engage> = -31    ; Incremental move to engage nut


; ================================
; MOTION + SPINDLE PARAMETERS
; ================================
#<spindle_rpm_engage>    = 900      ; Low RPM to start threading nut
#<feedrate_slow_z>       = 1000     ; Slow Z feed for controlled engagement (mm/min)
#<feedrate_fast_z>       = 2400     ; Fast Z feed for positioning moves (mm/min)

#<spindle_rpm_tighten>   = 1100     ; Final tightening speed
#<dwell_long>            = 2.0      ; Time to reach speed and fully tighten
#<dwell_spindle_stop>    = 1.0      ; Time to allow spindle to fully stop


; ================================
; INITIAL SETUP
; ================================
G17 G90 G40 G49                   ; Standard modal states
G53 G0 Z#<z_safe_machine>         ; Move to safe Z (machine coordinates)


; ================================
; MOVE TO ATC POSITION
; ================================
;(DEBUG, ATC: Move to ATC pocket position - remove after development if needed)

G53 G0 X101.142 Y-185.572        ; ATC pocket location


; ================================
; APPROACH TOOL HOLDER
; ================================
;(DEBUG, ATC: Engaging for screw)

G53 G1 Z#<z_engage_position> F#<feedrate_fast_z>   ; Rapid approach above nut

G91                                                 ; Switch to incremental mode

; Begin threading: slow rotation + controlled Z feed
M3 S#<spindle_rpm_engage>                            ; Clockwise rotation (threading direction)
G1 Z#<z_step_initial_engage> F#<feedrate_slow_z>     ; Lower slowly to engage nut threads


; ================================
; TIGHTEN TOOL
; ================================
;(DEBUG, ATC: Locking nut - spinning to tighten)

M3 S#<spindle_rpm_tighten>    ; Increase speed to fully tighten tool
G4 P#<dwell_long>             ; Allow time to reach speed and seat tool

M5                            ; Stop spindle
G4 P#<dwell_spindle_stop>     ; Ensure spindle has fully stopped


; ================================
; RETRACT
; ================================
G90                                ; Return to absolute positioning

;(DEBUG, ATC: Retracting to safe height)

G53 G0 Z#<z_safe_machine>          ; Retract to safe Z


; ================================
; DEVELOPMENT / MANUAL POSITION
; ================================
G53 G0 X40 Y-61.13                ; Temporary position for manual access
                                 ; TODO: remove after development


;(DEBUG, ATC: Load complete)

;o<open_atc_loading> endsub

M2 ; TODO: remove after full integration